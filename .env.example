# Core
SUNAVE_ENV=development
SUNAVE_LOG_LEVEL=info
SUNAVE_TENANCY_MODE=shared

# App ports
API_PORT=8080
WEB_PORT=3000

# Shared external infrastructure (managed outside this repo)
DATABASE_URL=******postgres:5432/sunave
REDIS_URL=redis://redis:6379/0

# External AI platform services
AI_GATEWAY_URL=http://litellm-gateway:4000
OLLAMA_BASE_URL=http://external-ollama:11434
STT_SERVICE_URL=http://external-stt:9000
TTS_SERVICE_URL=http://external-tts:9100

# Capability-first AI request defaults
AI_DEFAULT_CAPABILITY=text_generation
AI_REQUEST_TIMEOUT_MS=30000
