# Core
NODE_ENV=production
LOG_LEVEL=info
SUNAVE_TENANCY_MODE=shared

# Required URLs
FRONTEND_URL=https://enterprise.sunave.tech
API_BASE_URL=https://enterprise-api.sunave.tech

# Required Secrets
JWT_SECRET=CHANGE_ME

# App ports
PORT=8080
WEB_PORT=3000
WEB_API_TARGET=https://enterprise-api.sunave.tech

# Optional Services (commented out until configured)
# DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/sunave?sslmode=require
# REDIS_URL=redis://redis:6379/0
# AI_GATEWAY_URL=http://litellm-gateway:4000
# OLLAMA_URL=http://external-ollama:11434

RUN_MIGRATIONS_ON_BOOT=true
